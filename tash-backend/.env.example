# ---- TASH backend environment ----
# Async SQLAlchemy URL (asyncpg driver). Must match docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://tash:tash@localhost:5432/tash

# Telegram Bot token (from @BotFather). Used for Mini App initData HMAC + Bot API.
BOT_TOKEN=123456:REPLACE_ME

# Secret for signing owner/master JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# Timezone for all business logic. Stored data is tz-aware UTC.
APP_TZ=Asia/Tashkent

# URL of the Telegram Mini App (used in confirmation messages / deep links).
MINIAPP_URL=https://t.me/your_bot/app

# How old (hours) a Telegram initData auth_date may be before it is rejected.
TELEGRAM_AUTH_MAX_AGE_HOURS=24

# JWT access token lifetime (minutes).
JWT_EXPIRE_MINUTES=720

# ---- Payme (merchant) ----
# Merchant key issued by Payme; used to verify the Basic auth header on the webhook.
PAYME_MERCHANT_KEY=REPLACE_ME
# 'test' or 'production' — only used for logging/branching if needed.
PAYME_ENV=test

# ---- Click (SHOP-API) ----
CLICK_SERVICE_ID=REPLACE_ME
CLICK_MERCHANT_ID=REPLACE_ME
CLICK_SECRET_KEY=REPLACE_ME
CLICK_MERCHANT_USER_ID=REPLACE_ME
