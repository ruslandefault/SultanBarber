# Backend base URL.
# For Telegram Mini App usage the backend must be reachable over HTTPS
# (e.g. a public tunnel URL); for local browser dev use http://localhost:8001.
VITE_API_URL=http://localhost:8001

# Use the in-memory mock API (no Telegram / no backend needed) when 'true'.
# Default (unset or anything else) = call the real backend.
VITE_USE_MOCK=false
